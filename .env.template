# Copy this file to .env and fill in the values you use for release builds.
# .env is ignored by Git.

# Optional: choose the Developer ID Application certificate if your keychain has
# more than one matching identity.
# Use the certificate name without the "Developer ID Application: " prefix.
# CSC_NAME="Your Name or Company (TEAMID)"

# Optional for CI: use a certificate file or base64-encoded certificate instead
# of a local Keychain certificate.
# CSC_LINK="/absolute/path/developer-id-application.p12"
# CSC_KEY_PASSWORD="certificate-password"

# Notarization option 1: Apple Account app-specific password.
# APPLE_ID="you@example.com"
# APPLE_APP_SPECIFIC_PASSWORD="xxxx-xxxx-xxxx-xxxx"
# APPLE_TEAM_ID="YOURTEAMID"

# Notarization option 2: App Store Connect API key.
# APPLE_API_KEY="/absolute/path/AuthKey_XXXXXXXXXX.p8"
# APPLE_API_KEY_ID="XXXXXXXXXX"
# APPLE_API_ISSUER="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Notarization option 3: notarytool keychain profile.
# APPLE_KEYCHAIN_PROFILE="mac-remote-notary"
# APPLE_KEYCHAIN="/absolute/path/to/custom.keychain-db"
